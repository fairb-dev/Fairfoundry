      "upper_limit": 10,
      "unit": "ppm",
      "section_ref": "Section 3.4.2",
      "notes": "Per AAPFCO SUIP #25"
    },
    {
      "criterion_id": "C008",
      "parameter": "Lead",
      "maps_to_column": "lead_ppm",
      "type": "NUMERIC_LTE",
      "upper_limit": 61,
      "unit": "ppm",
      "section_ref": "Section 3.4.3",
      "notes": "Per AAPFCO SUIP #25"
    },
    {
      "criterion_id": "C009",
      "parameter": "Mercury",
      "maps_to_column": "mercury_ppm",
      "type": "NUMERIC_LTE",
      "upper_limit": 1,
      "unit": "ppm",
      "section_ref": "Section 3.4.4",
      "notes": "Per AAPFCO SUIP #25"
