      "unit": "%",
      "section_ref": "Section 3.1.1",
      "notes": "10.0% guaranteed minus 0.49% AAPFCO investigative allowance"
    },
    {
      "criterion_id": "C002",
      "parameter": "Available phosphoric acid (P2O5)",
      "maps_to_column": "avail_p2o5_pct",
      "type": "NUMERIC_GTE",
      "lower_limit": 9.33,
      "unit": "%",
      "section_ref": "Section 3.1.2",
      "notes": "10.0% guaranteed minus 0.67% AAPFCO investigative allowance"
    },
    {
      "criterion_id": "C003",
      "parameter": "Soluble potash (K2O)",
      "maps_to_column": "soluble_k2o_pct",
      "type": "NUMERIC_GTE",
      "lower_limit": 9.59,
      "unit": "%",
      "section_ref": "Section 3.1.3",
      "notes": "10.0% guaranteed minus 0.41% AAPFCO investigative allowance"
    },
    {
      "criterion_id": "C004",
      "parameter": "Moisture content",
      "maps_to_column": "moisture_pct",
      "type": "NUMERIC_LTE",
      "upper_limit": 1.5,
      "unit": "%",
