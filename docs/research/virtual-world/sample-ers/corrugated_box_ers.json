      "section_ref": "Section 3.1.1",
      "notes": "275# test liner per TAPPI T810"
    },
    {
      "criterion_id": "C002",
      "parameter": "Edge crush test (ECT)",
      "maps_to_column": "ect_lbf_in",
      "type": "NUMERIC_GTE",
      "lower_limit": 44,
      "unit": "lbf/in",
      "section_ref": "Section 3.1.2",
      "notes": "C-flute 44 ECT per TAPPI T811"
    },
    {
      "criterion_id": "C003",
      "parameter": "Flat crush resistance",
      "maps_to_column": "flat_crush_lbf_in2",
      "type": "NUMERIC_GTE",
      "lower_limit": 35,
      "unit": "lbf/in2",
