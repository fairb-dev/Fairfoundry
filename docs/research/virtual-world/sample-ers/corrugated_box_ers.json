      "notes": "C-flute per TAPPI T825"
    },
    {
      "criterion_id": "C004",
      "parameter": "Box compression test (BCT)",
      "maps_to_column": "bct_lbf",
      "type": "NUMERIC_GTE",
      "lower_limit": 1500,
      "unit": "lbf",
