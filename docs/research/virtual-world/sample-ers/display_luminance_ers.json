{
  "ers_id": "ERS-004",
  "title": "Display Panel Luminance and Color Accuracy Specification",
  "revision": "2.0",
  "product": "15.6-inch IPS LCD Panel LP-156",
  "stage": "MP",
  "issued_by": "ViewMax Display Corp. (OEM)",
  "factory": "Kunshan Optical Display Co.",
  "effective_date": "2026-02-15",
  "test_conditions": {
    "temperature_c": { "nominal": 25, "tolerance": 2 },
    "humidity_pct": { "max": 55 },
    "warm_up_minutes": 30
  },
  "acceptance_criteria": [
    {
      "criterion_id": "C001",
      "parameter": "Peak luminance",
      "maps_to_column": "peak_lum_cdm2",
      "type": "NUMERIC_GTE",
      "lower_limit": 400.0,
      "unit": "cd/m2",
      "section_ref": "Section 6.1.1",
      "notes": "Peak white luminance at center of panel"
    },
    {
      "criterion_id": "C002",
      "parameter": "Sustained luminance",
      "maps_to_column": "sustained_lum_cdm2",
      "type": "NUMERIC_GTE",
      "lower_limit": 250.0,
      "unit": "cd/m2",
      "section_ref": "Section 6.1.2",
      "notes": "Full-screen white sustained luminance after 10-minute window"
    },
    {
      "criterion_id": "C003",
      "parameter": "Black level luminance",
      "maps_to_column": "black_level_cdm2",
      "type": "NUMERIC_LTE",
      "upper_limit": 0.35,
      "unit": "cd/m2",
      "section_ref": "Section 6.1.3",
      "notes": "Full-screen black level measured in dark room"
    },
    {
      "criterion_id": "C004",
      "parameter": "Contrast ratio",
      "maps_to_column": "contrast_ratio",
      "type": "NUMERIC_GTE",
      "lower_limit": 1200,
      "unit": ":1",
      "section_ref": "Section 6.2.1",
      "notes": "Static contrast ratio (peak white / black level)"
    },
    {
      "criterion_id": "C005",
      "parameter": "BT.709 color gamut coverage",
      "maps_to_column": "bt709_coverage_pct",
      "type": "NUMERIC_GTE",
      "lower_limit": 99.0,
      "unit": "%",
      "section_ref": "Section 6.3.1",
      "notes": "Percentage of BT.709 / sRGB color space covered"
    },
    {
      "criterion_id": "C006",
      "parameter": "DCI-P3 color gamut coverage",
      "maps_to_column": "dcip3_coverage_pct",
      "type": "NUMERIC_GTE",
      "lower_limit": 88.0,
      "unit": "%",
      "section_ref": "Section 6.3.2",
      "notes": "Percentage of DCI-P3 color space covered"
    },
    {
      "criterion_id": "C007",
      "parameter": "Luminance uniformity (9-point)",
      "maps_to_column": "uniformity_9pt_pct",
      "type": "NUMERIC_GTE",
      "lower_limit": 84.0,
      "unit": "%",
      "section_ref": "Section 6.4.1",
      "notes": "Minimum / maximum luminance ratio across 9 measurement points"
    },
    {
      "criterion_id": "C008",
      "parameter": "Average Delta E color accuracy",
      "maps_to_column": "delta_e_avg",
      "type": "NUMERIC_LTE",
      "upper_limit": 3.0,
      "unit": "dE",
      "section_ref": "Section 6.5.1",
      "notes": "Average Delta E 2000 across 24-patch color checker"
    },
    {
      "criterion_id": "C009",
      "parameter": "Mura defect count",
      "maps_to_column": "mura_defect_count",
      "type": "NUMERIC_LTE",
      "upper_limit": 0,
      "unit": "count",
      "section_ref": "Section 6.6.1",
      "notes": "Visible mura (brightness non-uniformity) defects"
    }
  ],
  "sampling": {
    "method": "100_PERCENT",
    "aql": null
  },
  "disposition_rules": {
    "pass": "All criteria met; panel graded A or B",
    "conditional": "Minor criteria (C007, C008) marginally out; downgraded to Grade C",
    "fail": "Critical criteria (C001-C004) failed or mura detected"
  }
}
