      "unit": "um",
      "section_ref": "Section 4.1.2",
      "notes": "Measured via micro-CT per ASTM E1441"
    },
    {
      "criterion_id": "C003",
      "parameter": "Total porosity volume fraction",
      "maps_to_column": "total_porosity_vol_pct",
