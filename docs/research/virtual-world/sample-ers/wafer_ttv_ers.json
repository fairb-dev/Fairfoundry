      "unit": "um",
      "section_ref": "Section 3.1.1",
      "notes": "Per SEMI M1-0218"
    },
    {
      "criterion_id": "C002",
      "parameter": "Total thickness variation",
      "maps_to_column": "ttv_um",
      "type": "NUMERIC_LTE",
      "upper_limit": 3.0,
      "unit": "um",
      "section_ref": "Section 3.1.2",
      "notes": "Per SEMI MF1530, 5-point measurement"
    },
    {
      "criterion_id": "C003",
      "parameter": "Bow",
      "maps_to_column": "bow_um",
      "type": "NUMERIC_LTE",
      "upper_limit": 40,
      "unit": "um",
      "section_ref": "Section 3.2.1",
      "notes": "Free-standing wafer per SEMI MF1390"
    },
    {
      "criterion_id": "C004",
      "parameter": "Warp",
      "maps_to_column": "warp_um",
      "type": "NUMERIC_LTE",
      "upper_limit": 40,
      "unit": "um",
      "section_ref": "Section 3.2.2",
      "notes": "Per SEMI MF1390"
    },
    {
