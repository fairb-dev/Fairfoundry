      "section_ref": "Section 3.3.1",
      "notes": "Polished side per SEMI MF1811"
    },
    {
      "criterion_id": "C006",
      "parameter": "Global backside ideal range (GBIR)",
      "maps_to_column": "gbir_um",
      "type": "NUMERIC_LTE",
      "upper_limit": 2.0,
      "unit": "um",
      "section_ref": "Section 3.1.3",
      "notes": "Per SEMI M1"
    }
